# Скопируйте этот файл в .env и заполните реальными значениями:
#   cp .env.example .env

# --- База данных PostgreSQL ---
# Поменяйте YOUR_PASSWORD на свой пароль от PostgreSQL (тот что указали при установке)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/healthgo

# --- JWT ---
# Секретный ключ для подписи токенов. Любая длинная случайная строка.
# В команде используется общий — спросите у автора проекта.
JWT_SECRET=change-this-to-random-secret-string

# --- Google OAuth 2.0 ---
# Client ID из Google Cloud Console. Общий для всей команды.
# Спросите у автора проекта.
GOOGLE_CLIENT_ID=your-google-client-id-here

# --- Gmail SMTP для отправки писем восстановления пароля ---
# Gmail-аккаунт и App Password (не обычный пароль!).
# Как создать App Password: https://myaccount.google.com/apppasswords
# В команде используется общий — спросите у автора проекта.
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-16-char-app-password
FRONTEND_URL=http://localhost:8000
